# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; never commit real credentials.

# ── MySQL (maintenance database) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=maintenance
DB_USER=root
DB_PASSWORD=your_password_here

# ── MCP tool DB users (auto-created by mcp_server/setup_db_users.py) ──
# You do NOT fill these by hand — the helper generates the passwords and writes
# them here. maint_readonly = SELECT only; maint_write = INSERT/UPDATE on the two
# mutable tables only.
DB_READONLY_USER=maint_readonly
DB_READONLY_PASSWORD=<generated>
DB_WRITE_USER=maint_write
DB_WRITE_PASSWORD=<generated>

# ── Agentic FDM Services email (Gmail SMTP, free) ──
# Sender for send_email; recipients see the display name "Agentic FDM Services".
# AGENT_EMAIL_APP_PASSWORD is a Gmail *App Password* (16 chars) — enable
# 2-Step Verification, then Google Account → Security → App passwords.
AGENT_EMAIL=your_service_account@gmail.com
AGENT_EMAIL_APP_PASSWORD=your_gmail_app_password_here

# Seed notification recipients (optional). generate_data.py writes these as the
# demo employees' emails; default to example.com (never delivers). Set them to real
# inboxes YOU control to actually receive the send_email demo — they live only in
# this git-ignored .env, so real addresses never reach the public repo.
SEED_OPERATOR_EMAIL=you+operator@gmail.com
SEED_TECHNICIAN_EMAIL=you+technician@gmail.com
SEED_SUPERVISOR1_EMAIL=you+supervisor1@gmail.com
SEED_SUPERVISOR2_EMAIL=you+supervisor2@gmail.com

# ── Agent LLMs (free tiers, API-based) ──
# GROQ_API_KEY  → https://console.groq.com  (reasoning: Llama 3.3 70B; also the Qwen-3 judge fallback)
# GOOGLE_API_KEY → https://aistudio.google.com  (judge: Gemini 2.5 Flash-Lite)
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_ai_studio_key_here
# OPTIONAL secondary keys — if set, llms.py fails over to them on a rate-limit /
# quota / capacity error so a turn can still finish (not on request/validation bugs).
# Groq's free token cap is per-ACCOUNT, so a 2nd Groq key from the SAME account
# shares that cap; it adds real headroom only from a separate account.
GROQ_API_KEY_2=your_second_groq_key_here
GOOGLE_API_KEY_2=your_second_google_key_here

# ── Observability (LangSmith) — Phase 5 ──
# Free Developer tier → https://smith.langchain.com  (Settings → API Keys)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_key_here          # lsv2_pt_...
LANGSMITH_PROJECT=your_langsmith_project_name_here
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com   # use eu.api.smith.langchain.com if your org is EU
# LANGSMITH_REVIEW_QUEUE=fdm-review                    # annotation queue for flagged runs (Phase 5f)

# ── Eval judge (Phase 5c, OpenRouter — separate quota from the app) ──
OPENROUTER_API_KEY=your_openrouter_key_here        # https://openrouter.ai/keys
# Independent free judge (Qwen-3 — distinct family from Llama diagnoser + Gemini verifier).
# Free models are rate-limited upstream; for reliable LLM-judge scores use a cheap paid
# model, e.g. EVAL_JUDGE_MODEL=deepseek/deepseek-chat-v3-0324
EVAL_JUDGE_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ── RAG tuning (optional; sensible defaults, no need to set) ──
# EMBEDDING_DEVICE=cpu       # force the embedding device (cpu / cuda / mps); default auto-selects CUDA>CPU (MPS skipped)
# RERANK_MAX_LENGTH=512      # cross-encoder reranker max sequence length
